// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id                      String                  @id @default(uuid())
  nombre                  String
  direccion               String
  tableros                Tablero[]
  inspeccionesSubestacion InspeccionSubestacion[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@map("empresas")
}

model Tablero {
  id                     String     @id @default(uuid())
  nombre                 String     // Nombre o código del tablero (Ej: "Tablero No. 11")
  ubicacion              String
  alimentadoPor          String
  tipo                   String     // "superficial" | "empotrado"
  foto                   String?    // Foto del tablero (Base64)
  
  // Mediciones de corriente/voltaje
  ia                     String?
  ib                     String?
  ic                     String?
  va                     String?
  vb                     String?
  vc                     String?
  acometida              String?

  // Datos de cierre (calibre de neutro, tierra, observaciones)
  neutroCalibre          String?
  neutroObservaciones    String?
  tierraCalibre          String?
  tierraObservaciones    String?
  observacionesGenerales String?

  // Relaciones
  empresaId              String
  empresa                Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  circuitos              Circuito[]

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@map("tableros")
}

model Circuito {
  id               String   @id @default(uuid())
  numeroPolo       Int      // Del 1 al 42
  equipo           String?  // Equipo que alimenta
  breakerMarca     String?
  breakerTipo      String?
  breakerAmperaje  String?
  conductorCalibre String?

  // Relaciones
  tableroId        String
  tablero          Tablero  @relation(fields: [tableroId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("circuitos")
}

model InspeccionSubestacion {
  id                 String   @id // UUID v4 del cliente
  nombre             String   // Nombre o código de la subestación
  ubicacion          String   // Ubicación física
  fecha              String
  hora               String
  inspector          String
  nivelTension       String   // Nivel de tensión (kV)

  // Bloques de evaluación visual estructurada como JSON nativo de PostgreSQL
  estadoEntorno      Json
  obrasCiviles       Json
  equiposPrincipales Json
  puestaTierra       Json
  edificioControl    Json

  firmaInspector     String?
  firmaSupervisor    String?

  // Relaciones
  empresaId          String
  empresa            Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("inspecciones_subestacion")
}
