// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id        String    @id @default(uuid())
  nombre    String
  direccion String
  tableros  Tablero[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("empresas")
}

model Tablero {
  id                     String     @id @default(uuid())
  nombre                 String     // Nombre o código del tablero (Ej: "Tablero No. 11")
  ubicacion              String
  alimentadoPor          String
  tipo                   String     // "superficial" | "empotrado"
  
  // Mediciones de corriente/voltaje
  ia                     String?
  ib                     String?
  ic                     String?
  va                     String?
  vb                     String?
  vc                     String?
  acometida              String?

  // Datos de cierre (calibre de neutro, tierra, observaciones)
  neutroCalibre          String?
  neutroObservaciones    String?
  tierraCalibre          String?
  tierraObservaciones    String?
  observacionesGenerales String?

  // Relaciones
  empresaId              String
  empresa                Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  circuitos              Circuito[]

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Restricción única compuesta
  @@unique([empresaId, nombre])
  @@map("tableros")
}

model Circuito {
  id               String   @id @default(uuid())
  numeroPolo       Int      // Del 1 al 42
  equipo           String?  // Equipo que alimenta
  breakerMarca     String?
  breakerTipo      String?
  breakerAmperaje  String?
  conductorCalibre String?

  // Relaciones
  tableroId        String
  tablero          Tablero  @relation(fields: [tableroId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("circuitos")
}
