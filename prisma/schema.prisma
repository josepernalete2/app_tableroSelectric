// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoElemento {
  TABLERO
  SUBESTACION
  TRANSFORMADOR
  GENERADOR
  PUESTA_TIERRA
  TRANSFER
  OTRO
}

model Empresa {
  id                      String                  @id @default(uuid())
  nombre                  String
  direccion               String
  proyectos               Proyecto[]
  elementosUnifilares     ElementoUnifilar[]
  inspeccionesSubestacion InspeccionSubestacion[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@map("empresas")
}

model Proyecto {
  id                      String                  @id
  nombre                  String
  descripcion             String?
  fechaCreacion           DateTime                @default(now())

  // Relaciones
  empresaId               String
  empresa                 Empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  elementosUnifilares     ElementoUnifilar[]
  inspeccionesSubestacion InspeccionSubestacion[]

  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@map("proyectos")
}

model ElementoUnifilar {
  id                     String       @id @default(uuid())
  nombre                 String
  tipoElemento           TipoElemento
  ubicacion              String?
  alimentadoPor          String?
  foto                   String?
  observacionesGenerales String?
  datosTecnicos          Json

  // Relaciones
  proyectoId             String
  proyecto               Proyecto     @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  empresaId              String?
  empresa                Empresa?     @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([empresaId])
  @@map("elementos_unifilares")
}

model InspeccionSubestacion {
  id                 String   @id // UUID v4 del cliente
  nombre             String   // Nombre o código de la subestación
  ubicacion          String   // Ubicación física
  fecha              String
  hora               String
  inspector          String
  nivelTension       String   // Nivel de tensión (kV)

  // Bloques de evaluación visual estructurada como JSON nativo de PostgreSQL
  estadoEntorno      Json
  obrasCiviles       Json
  equiposPrincipales Json
  puestaTierra       Json
  edificioControl    Json

  firmaInspector     String?
  firmaSupervisor    String?

  // Relaciones
  proyectoId         String
  proyecto           Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  empresaId          String?
  empresa            Empresa? @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([empresaId])
  @@map("inspecciones_subestacion")
}
